# =========================================================================
# CloudRedirect Installer - Versão Direta (v2.2.1 Atualizada)
# =========================================================================
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13

$Host.UI.RawUI.WindowTitle = "CloudRedirect Installer | Loja GameOver v2.2.1"
Clear-Host

$LinkDoFixer = "https://github.com/Selectively11/CloudRedirect/releases/download/v2.2.1/CloudRedirectCLI.exe"
$LinkDaDll   = "https://github.com/Selectively11/CloudRedirect/releases/download/v2.2.1/cloud_redirect.dll"

function Log {
    param ([string]$Type, [string]$Message, [boolean]$NoNewline = $false)
    $Type = $Type.ToUpper()
    $color = switch ($Type) {
        "OK"   { "Green" }
        "INFO" { "Cyan" }
        "ERR"  { "Red" }
        "WARN" { "Yellow" }
        "LOG"  { "Magenta" }
        default { "White" }
    }
    $date = Get-Date -Format "HH:mm:ss"
    $prefix = if ($NoNewline) { "`r[$date] " } else { "[$date] " }
    Write-Host $prefix -ForegroundColor Cyan -NoNewline
    Write-Host "[$Type] $Message" -ForegroundColor $color -NoNewline:$NoNewline
}

function Get-DetailedError {
    param ($Exception)
    $msg = $Exception.Message
    if ($msg -match "Access to the path" -or $msg -match "UnauthorizedAccess") {
        return "Erro de Permissao: O script precisa ser executado como Administrador."
    } elseif ($msg -match "The remote name could not be resolved" -or $msg -match "connection") {
        return "Erro de Rede: Verifique sua conexao com a internet."
    } elseif ($msg -match "Antivirus" -or $msg -match "Trojan" -or $msg -match "security") {
        return "Bloqueio de Antivirus/Windows Defender: O arquivo foi colocado em quarentena."
    } else {
        return "Erro desconhecido: $msg"
    }
}

Log "INFO" "Searching for Steam installation..."
function Find-SteamPath {
    $PossiblePaths = @()
    try { $reg = Get-ItemProperty -Path "HKLM:\SOFTWARE\WOW6432Node\Valve\Steam" -ErrorAction SilentlyContinue; if ($reg.InstallPath) { $PossiblePaths += $reg.InstallPath } } catch {}
    try { $reg = Get-ItemProperty -Path "HKCU:\Software\Valve\Steam" -ErrorAction SilentlyContinue; if ($reg.SteamPath) { $PossiblePaths += $reg.SteamPath -replace '\\\\', '\' } } catch {}
    $DefaultPath = "C:\Program Files (x86)\Steam"
    if (Test-Path $DefaultPath) { $PossiblePaths += $DefaultPath }
    $PossiblePaths = $PossiblePaths | Select-Object -Unique | Where-Object { Test-Path $_ }
    if ($PossiblePaths.Count -eq 0) { Log "ERR" "Steam not found."; exit 1 }
    return $PossiblePaths[0]
}

$steamDir = Find-SteamPath
Log "INFO" "Closing Steam..."
Get-Process -Name "steam", "steamwebhelper" -ErrorAction SilentlyContinue | Stop-Process -Force
Start-Sleep -Seconds 2

# === CONTADOR DE 5 SEGUNDOS ===
Log "INFO" "Iniciando instalacao em 5 segundos..."
for ($i=5; $i -gt 0; $i--) {
    Write-Host "Iniciando em $i..." -ForegroundColor Yellow -NoNewline
    Start-Sleep -Seconds 1
    Write-Host "`r" -NoNewline
}
Write-Host "Executando agora!" -ForegroundColor Green

$tmpFolder = "C:\GameOver_Cloud_Tmp"
if (Test-Path $tmpFolder) { Remove-Item $tmpFolder -Recurse -Force -ErrorAction SilentlyContinue }
New-Item -ItemType Directory -Path $tmpFolder | Out-Null

$CliFile = Join-Path $tmpFolder "CloudRedirectCLI.exe"
$DllFile = Join-Path $tmpFolder "cloud_redirect.dll"

try {
    Log "LOG" "Baixando arquivos..."
    Invoke-WebRequest -Uri $LinkDoFixer -UserAgent "Mozilla/5.0" -OutFile $CliFile -ErrorAction Stop
    Invoke-WebRequest -Uri $LinkDaDll -UserAgent "Mozilla/5.0" -OutFile $DllFile -ErrorAction Stop
}
catch {
    Log "ERR" (Get-DetailedError $_.Exception)
    exit 1
}

Log "INFO" "Running Fixer..."
try {
    & $CliFile /stfixer
    Copy-Item -Path $DllFile -Destination (Join-Path $steamDir "cloud_redirect.dll") -Force -ErrorAction Stop
    Log "OK" "Operacao concluida com sucesso!"
}
catch {
    Log "ERR" (Get-DetailedError $_.Exception)
}

if (Test-Path $tmpFolder) { Remove-Item $tmpFolder -Recurse -Force -ErrorAction SilentlyContinue }
Log "INFO" "Iniciando Steam..."
Start-Process (Join-Path $steamDir "steam.exe") -ArgumentList "-clearbeta -no-browser +open steam://open/minigameslist"
[Environment]::Exit(0)
